<section id="contact" class="add-padding">
    <div class="container text-center">
        <div class="row">
            <div class="col-sm-6 col-md-5 text-left scrollimation fade-up d1">
                <h2 class="big-text">Contact Me</h2>
                <p class="lead">
                    Maybe I can help you with your next project?
                </p>
                <p>
                    Please fill in the contact form and I will get back to you.
                </p>
            </div>

            <!-- Netlify Forms Core Injection Wrapper -->
            <form id="contact-form" class="col-sm-6 col-md-offset-1 scrollimation fade-left d3" name="portfolio-contact" method="POST"
                data-netlify="true" netlify-honeypot="bot-field">
                <!-- Hidden Anti-Spam Honeypot Field Layer -->
                <p class="hidden" style="display: none;">
                    <label>Don’t fill this out if you're human: <input name="bot-field" /></label>
                </p>

                <div class="form-group">
                    <label class="control-label" for="contact-name">Name</label>
                    <div class="controls">
                        <input id="contact-name" name="name" placeholder="Your name" class="form-control requiredField"
                            data-new-placeholder="Your name" data-error-empty="Please enter your name" required>
                        <i class="fa fa-user" aria-hidden="true"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label" for="contact-mail">Email</label>
                    <div class=" controls">
                        <input id="contact-mail" name="email" placeholder="Your email" class="form-control requiredField"
                            data-new-placeholder="Your email" type="email" data-error-empty="Please enter your email"
                            data-error-invalid="Invalid email address" required>
                        <i class="fa fa-envelope" aria-hidden="true"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label" for="contact-message">Message</label>
                    <div class="controls">
                        <textarea id="contact-message" name="message" placeholder="Your message" class="form-control requiredField"
                            data-new-placeholder="Your message" rows="6" data-error-empty="Please enter your message" required></textarea>
                        <i class="fa fa-comment" aria-hidden="true"></i>
                    </div>
                </div>

                <p>
                    <button name="submit" type="submit" class="btn btn-color2 btn-block">
                        <i class="fa fa-paper-plane" aria-hidden="true"></i>Send Message
                    </button>
                </p>
            </form>
        </div>
    </div>
</section>